# App
APP_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# WhatsApp Cloud API
WA_PHONE_NUMBER_ID=your-phone-number-id
WA_ACCESS_TOKEN=your-whatsapp-access-token
WA_VERIFY_TOKEN=nageos-webhook-verify-token-2024
WA_APP_SECRET=your-meta-app-secret

# AI
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_AI_MODEL=anthropic/claude-sonnet-4-5

# Payments
PAYSTACK_SECRET_KEY=sk_test_your-paystack-key
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your-flutterwave-key

# Sentry
SENTRY_DSN=your-sentry-dsn

# Admin
ADMIN_EMAIL=your@email.com